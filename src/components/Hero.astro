---
import { Image } from 'astro:assets';
// ★ エイリアス（@assets）とあなたの正しいファイル名でインポート ★
import GlobalGraphic from '@assets/global_network_graphic.png'; 
---

<section class="bg-[#0A1428] text-white min-h-[90vh] flex items-center relative overflow-hidden py-16">
  
  <div class="relative z-10 w-full text-center px-4 max-w-6xl mx-auto">
    <h1 
      class="text-6xl sm:text-7xl lg:text-[7.5rem] leading-none font-black tracking-tight"
      style="font-family: 'Arial Black', sans-serif;"
    >
      CREATE VALUE BEYOND BORDERS
    </h1>
    <p class="text-xl sm:text-2xl font-semibold mt-6 text-[#4a90e2] tracking-wider">
      国を超えて価値を創造する
    </p>
  </div>

  <div class="absolute right-0 top-0 h-full w-full pointer-events-none hidden md:block">
    <Image 
      src={GlobalGraphic} 
      alt="Global network visualization graphic" 
      class="absolute right-0 top-0 h-auto w-auto max-h-[80vh]"
      style={{ opacity: 0.15, transform: 'translateY(15%)' }}
      loading="eager"
      widths={[300, 600, 1024, 1536]}
      sizes="(max-width: 768px) 0px, 50vw"
    />
  </div>
</section>